<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    
    <!-- Background work permissions for reliable SMB operations -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" tools:targetApi="33" />
    
    <!-- Request to ignore battery optimizations for reliable background operation -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".SambaLiteApp"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SambaLite">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize"
            android:windowSoftInputMode="adjustResize|stateHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.FileBrowserActivity"
            android:exported="false"
            android:theme="@style/Theme.SambaLite.NoActionBar"
            android:windowSoftInputMode="adjustResize|stateHidden"
            android:parentActivityName=".ui.MainActivity"
            android:launchMode="singleTop">
        </activity>

        <activity
            android:name=".ui.ShareReceiverActivity"
            android:exported="true"
            android:theme="@style/Theme.SambaLite.Dialog"
            android:excludeFromRecents="true"
            android:windowSoftInputMode="adjustResize|stateHidden">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.TransferQueueActivity"
            android:exported="false"
            android:theme="@style/Theme.SambaLite"
            android:parentActivityName=".ui.FileBrowserActivity" />
        <activity
            android:name=".ui.SystemMonitorActivity"
            android:exported="false"
            android:theme="@style/Theme.SambaLite"
            android:parentActivityName=".ui.MainActivity" />
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.SambaLite.NoActionBar"
            android:parentActivityName=".ui.MainActivity" />
        <activity
            android:name=".ui.FileViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.SambaLite.Viewer"
            android:parentActivityName=".ui.FileBrowserActivity" />

        <!-- FileProvider for sharing cached files with external apps -->
        <provider
            android:name="de.schliweb.sambalite.util.OpenFileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Foreground Service for background SMB operations -->
        <service
            android:name=".service.SmbBackgroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <!-- Disable default WorkManager initializer; SambaLiteApp provides custom config -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- WorkManager foreground service for sync operations -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />
    </application>

</manifest>
