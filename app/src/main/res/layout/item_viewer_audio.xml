<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <LinearLayout
        android:id="@+id/viewer_audio_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="40dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_file_audio"
            android:alpha="0.9"
            app:tint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewer_audio_play"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:contentDescription="@string/audio_play"
            app:icon="@drawable/ic_play"
            app:iconSize="40dp"
            app:iconGravity="textStart" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/viewer_audio_elapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@android:color/white"
                android:text="@string/audio_time_zero" />

            <com.google.android.material.slider.Slider
                android:id="@+id/viewer_audio_seek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:valueFrom="0"
                android:valueTo="1"
                app:thumbColor="@android:color/white"
                app:trackColorActive="@android:color/white"
                app:trackColorInactive="#66FFFFFF"
                app:labelBehavior="gone" />

            <TextView
                android:id="@+id/viewer_audio_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@android:color/white"
                android:text="@string/audio_time_zero" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/viewer_progress"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        app:indicatorColor="@android:color/white" />

    <TextView
        android:id="@+id/viewer_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="32dp"
        android:gravity="center"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="@android:color/white"
        android:visibility="gone" />

</FrameLayout>
