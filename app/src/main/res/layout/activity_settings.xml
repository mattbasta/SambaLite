<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ui.SettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/settings_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="8dp"
            android:paddingBottom="24dp">

            <!-- Security section -->
            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/security_options" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/auth_access_switch"
                style="@style/SettingsSwitch"
                android:text="@string/auth_required_for_access" />

            <TextView
                style="@style/SettingsSummary"
                android:text="@string/auth_required_for_access_summary" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/auth_password_reveal_switch"
                style="@style/SettingsSwitch"
                android:text="@string/auth_required_for_password_reveal" />

            <TextView
                style="@style/SettingsSummary"
                android:text="@string/auth_required_for_password_reveal_summary" />

            <TextView
                android:id="@+id/auth_not_available_text"
                style="@style/SettingsSummary"
                android:text="@string/auth_not_available"
                android:textColor="?attr/colorError"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Thumbnails section -->
            <TextView
                style="@style/SettingsSectionHeader"
                android:text="@string/thumbnails_section" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/show_thumbnails_switch"
                style="@style/SettingsSwitch"
                android:text="@string/show_thumbnails" />

            <TextView
                style="@style/SettingsSummary"
                android:text="@string/show_thumbnails_summary" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/thumbnail_lazy_switch"
                style="@style/SettingsSwitch"
                android:text="@string/thumbnail_lazy_tap" />

            <TextView
                style="@style/SettingsSummary"
                android:text="@string/thumbnail_lazy_tap_summary" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/thumbnail_size_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:hint="@string/thumbnail_size_limit">

                <AutoCompleteTextView
                    android:id="@+id/thumbnail_size_dropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    tools:ignore="LabelFor" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/SettingsSummary"
                android:text="@string/thumbnail_size_limit_summary" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
