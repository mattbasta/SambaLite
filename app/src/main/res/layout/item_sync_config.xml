<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sync_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Sync Icon Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/sync_icon_container"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/sync_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_sync"
            android:contentDescription="@string/content_desc_sync_indicator"
            app:tint="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/sync_progress"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminate="true"
            app:indicatorSize="20dp"
            app:trackThickness="2dp"
            app:indicatorColor="?attr/colorPrimary"
            app:trackColor="@android:color/transparent"
            tools:visibility="visible" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Sync Name (Local Folder Name) -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sync_local_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="?attr/colorOnSurface"
        android:ellipsize="middle"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@id/sync_more_options"
        app:layout_constraintStart_toEndOf="@id/sync_icon_container"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Documents" />

    <!-- Local Folder Path -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sync_local_path"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:ellipsize="start"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@id/sync_more_options"
        app:layout_constraintStart_toEndOf="@id/sync_icon_container"
        app:layout_constraintTop_toBottomOf="@id/sync_local_name"
        tools:text="/Documents/scans" />

    <!-- Sync Path (Remote Path) -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sync_remote_path"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:ellipsize="start"
        android:maxLines="1"
        app:layout_constraintEnd_toStartOf="@id/sync_more_options"
        app:layout_constraintStart_toEndOf="@id/sync_icon_container"
        app:layout_constraintTop_toBottomOf="@id/sync_local_path"
        tools:text="NAS/Public/Backup" />

    <!-- Sync Status / Last Sync -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sync_status"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorOutline"
        app:layout_constraintEnd_toStartOf="@id/sync_more_options"
        app:layout_constraintStart_toEndOf="@id/sync_icon_container"
        app:layout_constraintTop_toBottomOf="@id/sync_remote_path"
        tools:text="Last sync: 10 minutes ago" />

    <!-- Sync Direction Icon/Text -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sync_direction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorSecondary"
        app:layout_constraintStart_toStartOf="@id/sync_local_name"
        app:layout_constraintTop_toBottomOf="@id/sync_status"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="Local → Remote" />

    <!-- WiFi Only Indicator -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sync_wifi_only_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorTertiary"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/sync_direction"
        app:layout_constraintTop_toBottomOf="@id/sync_status"
        tools:text="WiFi only"
        tools:visibility="visible" />

    <!-- Mirror Indicator -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/sync_mirror_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorError"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/sync_wifi_only_indicator"
        app:layout_constraintTop_toBottomOf="@id/sync_status"
        tools:text="Mirror"
        tools:visibility="visible" />

    <!-- More Options Button -->
    <ImageButton
        android:id="@+id/sync_more_options"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/content_desc_more_options"
        android:src="@drawable/ic_menu_more"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurfaceVariant" />

</androidx.constraintlayout.widget.ConstraintLayout>
